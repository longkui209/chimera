# ============================================================
# Chimera 环境变量配置
# 复制为 .env 并根据实际环境调整
# ============================================================

# === API 服务 ===
CHIMERA_API_HOST=0.0.0.0
CHIMERA_API_PORT=8004

# === AI 模型路由 ===
CHIMERA_VISION_MODEL=gemini-2.5-flash
CHIMERA_REASONING_MODEL=deepseek-v4-pro
CHIMERA_CODE_MODEL=claude-sonnet-4

# === DAG 参数 ===
CHIMERA_DAG_TIMEOUT=600
CHIMERA_DAG_MAX_RETRIES=2
CHIMERA_DAG_PARALLEL_MAX=4

# === 提取参数 ===
CHIMERA_EXTRACT_TIMEOUT=300
CHIMERA_EXTRACT_MAX_FILES=10000

# === 游戏库路径 ===
CHIMERA_GAMES_PATH=/mnt/hgfs/common

# === 知识库路径 ===
CHIMERA_KB_PATH=/data/chimera/knowledge

# === 日志级别 ===
CHIMERA_LOG_LEVEL=INFO

# === 开发模式 ===
CHIMERA_DEBUG=false
